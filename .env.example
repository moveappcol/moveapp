# ============================================================
# CLERK (autenticación) — NECESARIO AHORA para correr el proyecto
# Crea una app gratis en https://dashboard.clerk.com, elige
# "Next.js" y copia las llaves de la sección API Keys.
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ============================================================
# AIRTABLE (base de datos) — se pedirá en el paso de "Gimnasios"
# API key: crea un Personal Access Token en
# https://airtable.com/create/tokens con scopes data.records:read
# y data.records:write sobre tu base.
# Base ID: lo encuentras en https://airtable.com/api con tu base abierta.
# ============================================================
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ============================================================
# WOMPI (pagos) — se pedirá en el paso de "Planes y pagos"
# Llaves disponibles en https://comercios.wompi.co (modo sandbox
# primero, luego producción).
# ============================================================
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=

# ============================================================
# SITIO / DOMINIO — se pedirá antes de desplegar en Railway
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
